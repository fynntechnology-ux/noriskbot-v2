# Wallet — base58 private key and corresponding public address
WALLET_PRIVATE_KEY=your_base58_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Trade settings
BUY_AMOUNT_SOL=0.03
HOLD_TIME_SECONDS=60
MAX_TOKEN_AGE_SECONDS=60

# Slippage: 0.50 = 50% (high slippage needed for sniping)
SLIPPAGE=0.50

# Max open positions at once
MAX_CONCURRENT_POSITIONS=10

# Priority fee: COMPUTE_UNIT_PRICE µL/CU × COMPUTE_UNIT_LIMIT CU = total priority fee in SOL
# Example: 12000 × 140000 = 1,680,000,000 µL = 0.00168 SOL
COMPUTE_UNIT_PRICE=12000
COMPUTE_UNIT_LIMIT=140000

# Helius Sender tip (lamports) — paid inside the tx for dual validator+Jito routing
# 1000000 = 0.001 SOL
SENDER_TIP_LAMPORTS=1000000

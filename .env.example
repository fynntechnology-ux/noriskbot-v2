# Wallet — base58 private key and corresponding public address
WALLET_PRIVATE_KEY=your_base58_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Trade settings
BUY_AMOUNT_SOL=0.06
HOLD_TIME_SECONDS=30
MAX_TOKEN_AGE_SECONDS=60

# Slippage: 0.10 = 10%
SLIPPAGE=0.10

# Max open positions at once
MAX_CONCURRENT_POSITIONS=5

# Priority fee: COMPUTE_UNIT_PRICE µL/CU × COMPUTE_UNIT_LIMIT CU
# 20000 × 85000 = 0.0017 SOL
COMPUTE_UNIT_PRICE=20000
COMPUTE_UNIT_LIMIT=85000

# Astralane tip (lamports) — paid inside the tx
# 1000 = 0.000001 SOL  (0.00001 SOL = 10000)
SENDER_TIP_LAMPORTS=1000

# Astralane Bearer auth key (required when NONCE_ACCOUNT is set)
ASTRALANE_API_KEY=

# Durable nonce account address (optional)
# Leave empty for normal blockhash mode.
# Run `python3 main.py --create-nonce` to create and fund a nonce account.
NONCE_ACCOUNT=

# Dedicated read RPC for getAccountInfo calls (bonding curve, nonce, reserves).
# Offloads heavy read traffic from Helius so the tx-submission quota is never starved.
# Recommended: Chainstack, QuickNode, dRPC, or any shared Solana RPC endpoint.
# Falls back to HELIUS_RPC_HTTP if left empty.
READ_RPC_HTTP=

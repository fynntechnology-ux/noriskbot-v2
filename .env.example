# GMGN API key — get from https://gmgn.ai/ai
GMGN_API_KEY=your_gmgn_api_key_here

# Your Ed25519 private key in PEM format (same key pair you uploaded to GMGN)
# Paste the full PEM block, using \n for newlines on a single line, e.g.:
# GMGN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMC4CAQ...\n-----END PRIVATE KEY-----
GMGN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----

# Your Solana wallet address (must match the wallet bound to your GMGN API key)
WALLET_ADDRESS=your_wallet_address_here

# Trade settings
BUY_AMOUNT_SOL=0.1
HOLD_TIME_SECONDS=60
MAX_TOKEN_AGE_SECONDS=60

# Trigger: buy at 0% bonding curve (right at launch — no threshold needed)

# Slippage: 0.5 = 50% (high slippage needed for sniping)
SLIPPAGE=0.5

# Max open positions at once
MAX_CONCURRENT_POSITIONS=3
